---
import AboutPage from "@/components/AboutPage/AboutPage.astro";
import { METADATA } from "@/const";
import Layout from "@/layouts/Layout.astro";
import { getPersonalData } from "@/data/personal";
import { getAboutCopy } from "@/libraries/about";

const copy = await getAboutCopy("en");
const personalData = getPersonalData("en");
---

<Layout title={`About - ${METADATA.title}`} lang="en">
  <AboutPage
    copy={copy}
    personalData={personalData}
    supplementalLink={{
      href: "/about/",
      label: "ja/en",
      ariaLabel: "日本語に切り替える",
    }}
  />
</Layout>
