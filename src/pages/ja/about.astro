---
import AboutPage from "@/components/AboutPage/AboutPage.astro";
import { METADATA } from "@/const";
import Layout from "@/layouts/Layout.astro";
import { getPersonalData } from "@/data/personal";
import { getAboutCopy } from "@/libraries/about";

const copy = await getAboutCopy("ja");
const personalData = getPersonalData("ja");
---

<Layout title={`About - ${METADATA.title}`} lang="ja">
  <AboutPage
    copy={copy}
    personalData={personalData}
    supplementalLink={{
      href: "/about/",
      label: "en/jp",
      ariaLabel: "Switch to English",
    }}
  />
</Layout>
