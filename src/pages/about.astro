---
import BackLink from "@/components/BackLink/BackLink.astro";
import Profile from "@/components/Profile/Profile.astro";
import WorksGrid from "@/components/WorksGrid/WorksGrid.astro";
import { METADATA, PERSONAL_DATA, type HistoryItem } from "@/const";
import Layout from "@/layouts/Layout.astro";
import styles from "@/styles/about.module.scss";

const parseYearMonth = (value: string) => {
  const [year, month] = value.split("-").map(Number);
  return year * 100 + month;
};

const sortByDateDesc = <T extends { date: string }>(items: T[]) =>
  [...items].sort((a, b) => parseYearMonth(b.date) - parseYearMonth(a.date));

const formatHistoryDate = (item: HistoryItem) => {
  if (item.current) {
    return `${item.start} ~ present`;
  }

  if (item.end) {
    return `${item.start} ~ ${item.end}`;
  }

  return item.start;
};

const sortHistory = (items: HistoryItem[]) =>
  [...items].sort((a, b) => {
    const endA = a.current
      ? Number.POSITIVE_INFINITY
      : parseYearMonth(a.end ?? a.start);
    const endB = b.current
      ? Number.POSITIVE_INFINITY
      : parseYearMonth(b.end ?? b.start);

    return endB - endA || parseYearMonth(b.start) - parseYearMonth(a.start);
  });

const sortedHistory = sortHistory(PERSONAL_DATA.history);
const educationHistory = sortedHistory.filter(
  (item) => item.type === "education"
);
const careerHistory = sortedHistory.filter((item) => item.type !== "education");
const sortedCerts = sortByDateDesc(PERSONAL_DATA.certs);
const sortedCtfs = sortByDateDesc(PERSONAL_DATA.ctfs);
---

<Layout title=`About - ${METADATA.title}`>
  <div class={styles.container}>
    <BackLink />
    <Profile mode="row" hideAbout class={styles.header} priority />
    <div class={styles.content}>
      <section class={styles.interests}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>興味のあること</h2>
        </div>
        <div class={styles.sectionContent}>
          <ul>
            {PERSONAL_DATA.interests.map((interest) => <li>{interest}</li>)}
          </ul>
        </div>
      </section>
      <section class={styles.likes}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>好きなもの</h2>
        </div>
        <div class={styles.sectionContent}>
          <ul>
            {PERSONAL_DATA.likes.map((like) => <li>{like}</li>)}
          </ul>
          <div class={styles.spotifyEmbed}>
            <iframe
              title="Top Tracks"
              src={`https://stats-embeds.kq5.jp/embed/top?user=${PERSONAL_DATA.statsfmUsername}`}
              width="100%"
              height="160"
              loading="lazy"></iframe>
          </div>
          <p>
            詳しくは<a href="/music/" class={styles.itemLink}>好きな音楽</a>へ
          </p>
        </div>
      </section>
      <section class={styles.history}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>学歴</h2>
        </div>
        <div class:list={[styles.sectionContent, styles.timeline]}>
          {
            educationHistory.map((item) => (
              <div class={styles.termTimelineItem}>
                <div class={styles.timelineDate}>{formatHistoryDate(item)}</div>
                <div class={styles.timelineContent}>
                  <h3>{item.title}</h3>
                  <div class={styles.contentMeta}>
                    {item.links && (
                      <div class={styles.itemLinks}>
                        {item.links.map((link) => (
                          <a
                            href={link.url}
                            class={styles.itemLink}
                            target={
                              link.url.startsWith("http") ? "_blank" : undefined
                            }
                            rel={
                              link.url.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                            }
                          >
                            {link.name}
                          </a>
                        ))}
                      </div>
                    )}
                    {item.description && <p>{item.description}</p>}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class={styles.history}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>経歴</h2>
        </div>
        <div class:list={[styles.sectionContent, styles.timeline]}>
          {
            careerHistory.map((item) => (
              <div class={styles.termTimelineItem}>
                <div class={styles.timelineDate}>{formatHistoryDate(item)}</div>
                <div class={styles.timelineContent}>
                  <h3>{item.title}</h3>
                  <div class={styles.contentMeta}>
                    {item.links && (
                      <div class={styles.itemLinks}>
                        {item.links.map((link) => (
                          <a
                            href={link.url}
                            class={styles.itemLink}
                            target={
                              link.url.startsWith("http") ? "_blank" : undefined
                            }
                            rel={
                              link.url.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                            }
                          >
                            {link.name}
                          </a>
                        ))}
                      </div>
                    )}
                    {item.description && <p>{item.description}</p>}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class={styles.certs}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>資格・受賞</h2>
        </div>
        <div class:list={[styles.sectionContent, styles.timeline]}>
          {
            sortedCerts.map((cert) => (
              <div class={styles.dateTimelineItem}>
                <div class={styles.timelineDate}>{cert.date}</div>
                <div class={styles.timelineContent}>
                  <h3>{cert.name}</h3>
                  <div class={styles.contentMeta}>
                    {cert.links && (
                      <div class={styles.itemLinks}>
                        {cert.links.map((link) => (
                          <a
                            href={link.url}
                            class={styles.itemLink}
                            target={
                              link.url.startsWith("http") ? "_blank" : undefined
                            }
                            rel={
                              link.url.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                            }
                          >
                            {link.name}
                          </a>
                        ))}
                      </div>
                    )}
                    {cert.description && <p>{cert.description}</p>}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class={styles.ctfs}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>CTF</h2>
        </div>
        <div class:list={[styles.sectionContent, styles.timeline]}>
          {
            sortedCtfs.map((ctf) => (
              <div class={styles.dateTimelineItem}>
                <div class={styles.timelineDate}>{ctf.date}</div>
                <div class={styles.timelineContent}>
                  <h3>{ctf.name}</h3>
                  <div class={styles.contentMeta}>
                    {ctf.links && (
                      <div class={styles.itemLinks}>
                        {ctf.links.map((link) => (
                          <a
                            href={link.url}
                            class={styles.itemLink}
                            target={
                              link.url.startsWith("http") ? "_blank" : undefined
                            }
                            rel={
                              link.url.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                            }
                          >
                            {link.name}
                          </a>
                        ))}
                      </div>
                    )}
                    <p>
                      {ctf.team} / {ctf.rank}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class={styles.works}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>制作物</h2>
          <a
            href="/works/"
            class={styles.sectionHeaderLink}
            aria-label="View all works"
          >
            View all works
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <WorksGrid onlyPinned={true} />
      </section>
      <section class={styles.extraLinks}>
        <div class={styles.sectionHeader}>
          <h2 class={styles.sectionTitle}>リンク</h2>
        </div>
        <div class={styles.sectionContent}>
          <ul>
            {
              PERSONAL_DATA.extraLinks.map((link) => (
                <li>
                  <a href={link.url} target="_blank" rel="noopener noreferrer">
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </div>
  </div>
</Layout>
